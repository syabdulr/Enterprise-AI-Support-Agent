"""
Example environment variables for Enterprise AI Support Agent.
Copy this file to .env and fill in your actual values.
"""

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=1000

# Vector Database Configuration
# Choose between 'pinecone' and 'chromadb'
VECTOR_DB_TYPE=chromadb

# For Pinecone (if using Pinecone)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment
PINECONE_INDEX_NAME=enterprise-ai-kb

# Application Configuration
LOG_LEVEL=INFO
MAX_AGENTS=10
MEMORY_LIMIT=100
MAX_CONVERSATION_TURNS=20

# Policy Configuration
MAX_URGENCY_THRESHOLD=critical
ESCALATION_TIMEOUT=300
APPROVAL_REQUIRED_FOR_CRITICAL=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4